{% from '_portfolio.jinja' import platform_repos, group_repos, repo_dir with context -%}
{%- set names = [] -%}
{%- for n in platform_repos().splitlines() -%}
  {%- set s = n | trim -%}
  {%- if s and not s.startswith('#') -%}{% set _ = names.append(repo_dir(s)) %}{%- endif -%}
{%- endfor -%}
{%- for g in portfolio_groups | sort -%}
  {%- for n in group_repos(g).splitlines() -%}
    {%- set s = n | trim -%}
    {%- if s and not s.startswith('#') -%}{% set _ = names.append(repo_dir(s)) %}{%- endif -%}
  {%- endfor -%}
{%- endfor -%}
{%- for n in extra_repos.splitlines() -%}
  {%- set s = n | trim -%}
  {%- if s and not s.startswith('#') -%}{% set _ = names.append(repo_dir(s)) %}{%- endif -%}
{%- endfor -%}
{%- set sorted_names = names | unique | sort(case_sensitive=false) -%}
{
  "folders": [
    {"name": {{ (ade_name ~ " (root)") | tojson }}, "path": "."}{% if sorted_names %},{% endif %}
{%- for name in sorted_names %}
    {"name": {{ name | tojson }}, "path": {{ name | tojson }}}{% if not loop.last %},{% endif %}
{%- endfor %}
  ],
  "settings": {
    "git.autoRepositoryDetection": false,
    "git.openRepositoryInParentFolders": "never",
    "files.exclude": {
      "**/.DS_Store": true
    }
  }
}
